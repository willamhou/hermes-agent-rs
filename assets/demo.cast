[3.623803, "o", "Interactive AI agent powered by Hermes\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m \u001b[1mhermes\u001b[0m [OPTIONS] [COMMAND]\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1mgateway\u001b[0m  Start the gateway server (Telegram, API)\r\n  \u001b[1mcron\u001b[0m     Cron job management\r\n  \u001b[1mhelp\u001b[0m     Print this message or the help of the given subcommand(s)\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n  \u001b[1m-m\u001b[0m, \u001b[1m--message\u001b[0m <MESSAGE>    Send a single message and print the response (non-interactive)\r\n      \u001b[1m--model\u001b[0m <MODEL>        Override the model (e.g. \"openai/gpt-4o\")\r\n      \u001b[1m--base-url\u001b[0m <BASE_URL>  Override the provider base URL\r\n      \u001b[1m--resume\u001b[0m [<RESUME>]    Resume a previous session. Pass session ID, or omit for most recent\r\n      \u001b[1m--list-sessions\u001b[0m        List recent sessions\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m                 Print help\r\n"]
